-- Функции
local function getTargets(targetAll, targetName)
    local targets = {}
    if targetAll then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player then table.insert(targets, plr) end
        end
    else
        local plr = Players:FindFirstChild(targetName)
        if plr and plr ~= player then table.insert(targets, plr) end
    end
    return targets
end

